                <td>$8.00</td>
                <td>50</td>
                <td>
                    <img src="product1.jpg" alt="Product 1" width="50" height="50">
                </td>
                <td>
                    <button class="btn btn-primary btn-sm">Edit</button>
                    <button class="btn btn-success btn-sm">List</button>
                    <button class="btn btn-danger btn-sm">Unlist</button>
                </td>
            </tr>
        </tbody>
    </table>
</div>
