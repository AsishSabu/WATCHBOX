<div class="container">
    <h1>Product Page</h1>
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>S.No</th>
                <th>Product Name</th>
                <th>Category</th>
                <th>Description</th>
                <th>Sales Price</th>
                <th>Product Price</th>
                <th>Quantity</th>
                <th>Images</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <!-- Sample Product Row (You can add more rows dynamically) -->
            <tr>
                <td>1</td>
                <td>Product 1</td>
                <td>Category 1</td>
                <td>Description 1</td>
