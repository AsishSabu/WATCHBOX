<style>
  body {
    background-color: #ffffff;

  padding: 10px;

  border-radius: 5px;
  font-weight: 800;
  }


  .container {
    z-index: -11111;
    position: absolute;
    margin-top: 4%;
    background-color: #fff;
    border: 1px solid #ffffff;
    border-radius: 5px;
    padding: 20px;

    box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
  }

  .form-group {
    margin-bottom: 20px;
  }

  label {
    font-weight: bold;
  }

  .form-control {
    width: 100%;
  }

  .btn-primary {
    background-color: #007bff;
    border: none;
  }

  .btn-primary:hover {
    background-color: #0056b3;
  }

  /* Additional styling for responsiveness */
  @media (max-width: 768px) {
    .container {
      margin: 20px;
    }
  }

  .image-container {
    position: relative;
  }

  .close-button {
    position: absolute;
    top: 5px;
    right: 5px;
    background: black;
    border: none;
    color: #dc3545; /* Bootstrap danger color */
    cursor: pointer;
  }
  #image-preview {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .img-thumbnail {
    border: 1px solid #ddd;
    border-radius: 5px;
    padding: 5px;
    box-shadow: 0 0 5px rgba(0, 0, 0, 0.1);
  }
</style>
<script>
document.addEventListener("DOMContentLoaded", function () {
  const productForm = document.getElementById("addProduct");
  const productInput = document.getElementById("productName");
  const nameerr = document.getElementById("nameerr");
  const descriptionInput = document.getElementById("description");
  const decerr = document.getElementById("decerr");
  const productPriceInput = document.getElementById("productPrice");
  const productPriceErr = document.getElementById("productPriceErr");
  const salePrice = document.getElementById("salePrice");
  const saleerr = document.getElementById("saleerr");
  const Quantity = document.getElementById("quantity");
  const Qerr = document.getElementById("qerr");
  const brand = document.getElementById("brand");
  const branderr = document.getElementById("branderr");
  const image = document.getElementById("product-images");
  const imageerr = document.getElementById("imageerr");
  const formerr = document.getElementById("formerr");

  function validateName() {
    const name = productInput.value.trim();

    if (name === "") {
      nameerr.textContent = "Field is required";
    } else if (name.length < 4) {
      nameerr.textContent = "Name must be at least 4 characters";
    } else {
      nameerr.textContent = "";
    }
  }

  productInput.addEventListener("blur", validateName);

  function validateDec() {
    const dec = descriptionInput.value.trim();

    if (dec === "") {
      decerr.textContent = "Field is required";
    } else if (dec.length < 10) {
      decerr.textContent = "Description must be at least 10 characters";
    } else {
      decerr.textContent = "";
    }
  }

  descriptionInput.addEventListener("blur", validateDec);

function validateProductPrice() {
  const price = parseFloat(productPriceInput.value.trim());

  if (isNaN(price)) {
    productPriceErr.textContent = "Please enter a valid number for the product price";
  } else if (price <= 0) {
    productPriceErr.textContent = "Price should be a positive number";
  } else {
    productPriceErr.textContent = "";
  }
}


  productPriceInput.addEventListener("blur", validateProductPrice);

 function validateSalePrice() {
  const price = parseFloat(salePrice.value.trim());

  if (isNaN(price)) {
    saleerr.textContent = "Please enter a valid number";
  } else if (price <= 0) {
    saleerr.textContent = "Price should be a positive number";
  } else {
    saleerr.textContent = "";
  }
}
  salePrice.addEventListener("blur", validateSalePrice);

  function validateBrandName() {
    const name = brand.value.trim();

    if (name === "") {
      branderr.textContent = "Field is required";
    } else {
      branderr.textContent = "";
    }
  }

  brand.addEventListener("blur", validateBrandName);

  function validateQuantity() {
  const quantity = parseFloat(Quantity.value.trim());

  if (isNaN(quantity)) {
    Qerr.textContent = "Please enter a valid number for quantity";
  } else if (quantity <= 0) {
    Qerr.textContent = "Quantity should be a positive number";
  } else {
    Qerr.textContent = "";
  }
}

  Quantity.addEventListener("blur", validatequantity);

  function validateBrandName() {
    const name = brand.value.trim();

    if (name === "") {
      branderr.textContent = "Field is required";
    } else {
      branderr.textContent = "";
    }
  }

  brand.addEventListener("blur", validateBrandName);

  function validateImage() {
    const files = image.files;
    if (files.length === 0) {
      imageerr.textContent = "Please select at least one image";
    } else if (files.length > 4) {
      imageerr.textContent = "Maximum of 4 images allowed";
    } else {
      imageerr.textContent = "";
    }
  }
image.addEventListener("change", validateImage);

  function handleSubmit(event) {
    event.preventDefault();

    validateBrandName();
    validateDec();
    validateName();
    validateProductPrice();
    validateSalePrice();
    validateQuantity();
    validateImage();

    const allErrors = [
      nameerr,
      decerr,
      productPriceErr,
      saleerr,
      Qerr,
      branderr,
      imageerr,
    ];

    // Check if there are any errors and if the number of files is within the limit
    const isFormValid = allErrors.every((error) => error.textContent === "") && image.files.length > 0 && image.files.length <= 4;

    if (isFormValid) {
      formerr.textContent = "";
      productForm.submit();
    } else {
      alert("Please provide appropriate data");
    }
  }

  productForm.addEventListener("submit", handleSubmit);
});

</script>

<script>
  document
    .getElementById("product-images")
    .addEventListener("change", function () {
      const previewContainer = document.getElementById("image-preview");
      previewContainer.innerHTML = ""; // Clear previous previews
      const files = this.files;
      for (let i = 0; i < files.length; i++) {
        const file = files[i];
        const reader = new FileReader();
        reader.onload = function (e) {
          const img = document.createElement("img");
          img.src = e.target.result;
          img.classList.add("img-thumbnail");
          img.style.maxWidth = "150px";
          img.style.maxHeight = "150px"; // Limit image height for a consistent layout

          const closeButton = document.createElement("button");
          closeButton.innerHTML = "&times;"; // Unicode character for 'times' (close) symbol
          closeButton.classList.add(
            "btn",
            "btn-sm",
            "btn-danger",
            "close-button"
          );
          closeButton.addEventListener("click", function () {
            previewContainer.removeChild(imageDiv);
          });

          const imageDiv = document.createElement("div");
          imageDiv.classList.add("image-container");
          imageDiv.appendChild(img);
          imageDiv.appendChild(closeButton);

          previewContainer.appendChild(imageDiv);
        };
        reader.readAsDataURL(file);
      }
    });
</script>
