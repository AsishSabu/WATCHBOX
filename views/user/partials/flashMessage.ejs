<% if (locals.messages) { %>
<div class="flash-messages">
  <% Object.keys(messages).forEach((key) => { %> <%
  messages[key].forEach((message) => { %>
  <div
    class="alert alert-<%= key !== `error` ? key : `danger` %> fade show"
    id="flash-message"
    role="alert"
  >
    <strong><%= key === "danger" ? "Error" : key %>!</strong> <%= message %>.
  </div>
  <% }) %> <% }) %>
</div>
<% } %>
<style>


  .alert {
    margin-bottom: 10px;
    opacity: 0;
    transition: opacity 0.5s;
  }

  .alert.show {
    opacity: 1;
  }

  .alert button.close {
    position: relative;
    top: -2px;
  }

  .alert-danger {
    background-color: #f44336;
    color: white;
  }

  .alert-success {
    background-color: #87c689;
    color: white;
  }
</style>
