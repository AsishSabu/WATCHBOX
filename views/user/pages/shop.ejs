  <div class="shop-page-wrapper shop-page-padding ptb-150">
    <div class="container-fluid">
      <div class="row gy-5">
        <div class="col-lg-3 order-2 order-lg-1">
          <div class="shop-sidebar mr-50">
            <div class="sidebar-widget mb-50">
              <h3 class="sidebar-title">Search Products</h3>
              <div class="sidebar-search">
                <form>
                  <input
                    placeholder="Search Products..."
                    type="text"
                    id="search"
                    name="search"
                  />
                  <button><i class="ti-search"></i></button>
                </form>
              </div>
            </div>
            <div class="sidebar-widget mb-40">
              <h3 class="sidebar-title">Filter by Price</h3>
              <div class="sidebar-categories">
                <ul>
                  <li><a href="/shop"> Default </a></li>
                  <li><a href="" id="lowToHigh"> Low to High </a></li>
                  <li><a href="" id="highToLow"> High to low </a></li>
                </ul>
              </div>
            </div>
            <div class="sidebar-widget mb-45">
              <h3 class="sidebar-title">Categories</h3>
              <div class="sidebar-categories">
                <ul>
                  <% if (category.length>0) { %> <% if(category.length > 1) { %>
                  <li><a href="/shop">All Categories</a></li>
                  <% } %> <% category.forEach(element=> { %>
                  <li>
                    <a
                      href="/shop?p=<%= currentPage %>&category=<%= element.categoryName %>"
                      <%
                      if
                      (selectedCategory
                      &&
                      selectedCategory.length
                      >0) { %> class="<%= selectedCategory.includes(element._id)
                      ? 'text-dark' : '' %>" <% } %>> <%= element.categoryName
                      %>
                    </a>
                  </li>
                  <% }); %> <% } else { %>
                  <h3>NO CATEGORIES</h3>
                  <% } %>
                </ul>
              </div>
            </div>
          </div>
        </div>
        <div class="col-lg-9 order-1 order-lg-2">
          <div class="shop-product-wrapper res-xl res-xl-btn">
            <div class="shop-bar-area">
              <div class="shop-bar pb-60">
                <div class="shop-found-selector"></div>
                <div class="shop-filter-tab">
                  <div class="shop-tab nav" role="tablist">
                    <a
                      class="active"
                      href="#grid-sidebar1"
                      data-bs-toggle="tab"
                      role="tab"
                      aria-selected="false"
                    >
                      <i class="ti-layout-grid4-alt"></i>
                    </a>
                    <a
                      href="#grid-sidebar2"
                      data-bs-toggle="tab"
                      role="tab"
                      aria-selected="true"
                    >
                      <i class="ti-menu"></i>
                    </a>
                  </div>
                </div>
              </div>
              <div class="shop-product-content tab-content">
                <div id="grid-sidebar1" class="tab-pane fade active show">
                  <div class="row">
                    <% products.forEach(product => { %>
                    <div class="col-lg-6 col-md-6 col-xl-3">
                      <div class="product-wrapper mb-30">
                        <div class="product-img">
                          <a href="#">
                            <img
                              src="<%= product.images[0].thumbnailUrl%>"
                              alt="<%= product.title %>"
                            />
                          </a>
                          <span>hot</span>
                          <div class="product-action">
                            <% if (userWishlist) { %> <% if
                            (userWishlist.includes(product._id)) { %>
                            <a
                              class="animate-right"
                              id="wishlist"
                              title="Wishlist"
                              onclick="toggleWishlist(`<%= product._id %>`)"
                              style="background-color: red"
                            >
                              <i class="pe-7s-like" id="wishlist"></i>
                            </a>
                            <% } else { %>
                            <a
                              class="animate-right"
                              id="wishlist"
                              title="Wishlist"
                              onclick="toggleWishlist(`<%= product._id %>`)"
                            >
                              <i class="pe-7s-like" id="wishlist"></i>
                            </a>

                            <% } %> <% } else { %>
                            <a
                              class="animate-right"
                              id="wishlist"
                              title="Wishlist"
                              href="/login"
                            >
                              <i class="pe-7s-like"></i
                            ></a>
                            <% } %> <% if(!user) {%>
                            <a
                              class="animate-top"
                              title="Add To Cart"
                              href="/login"
                            >
                              <i class="pe-7s-cart"></i>
                            </a>

                            <% }else{ %>
                            <a
                              class="animate-top"
                              title="Add To Cart"
                              onclick="addToCart('<%= product._id %>')"
                            >
                              <i class="pe-7s-cart"></i>
                            </a>

                            <% } %>
                            <a
                              class="animate-right"
                              title="Quick View"
                              href="/viewProduct/<%= product?._id %>"
                            >
                              <i class="pe-7s-look"></i>
                            </a>
                          </div>
                        </div>

                        <div class="product-content">
                          <h4><a href="#"><%= product.title%></a></h4>
                        </div>
                        <div class="d-flex justify-content-between">
                          <span
                            class="text-decoration-line-through text-secondary"
                          >
                            ₹ <%= product.productPrice %>
                          </span>
                          <span>₹ <%= product.salePrice %></span>
                        </div>
                      </div>
                    </div>

                    <div
                      id="fixed-div"
                      class="mt-2 fixed-div"
                      style="display: none"
                    >
                      <p
                        id="wishlist-message"
                        class="mb-0 text-light text-center"
                      ></p>
                    </div>
                    <% }) %>
                  </div>
                </div>
                <div id="grid-sidebar2" class="tab-pane fade">
                  <div class="row">
                     <% products.forEach(product => { %>
                    <div class="col-lg-12 col-xl-6">
                      <div
                        class="product-wrapper mb-30 single-product-list product-list-right-pr mb-60"
                      >
                        <div class="product-img list-img-width">
                          <a href="#">
                            <img
                                src="<%= product.images[0].thumbnailUrl%>"
                              alt="<%= product.title %>"
                            />
                          </a>
                          <span>hot</span>
                          <div class="product-action-list-style">
                            <a
                              class="animate-right"
                              title="Quick View"
                              data-bs-toggle="modal"
                              data-bs-target="#exampleModal"
                              href="#"
                            >
                              <i class="pe-7s-look"></i>
                            </a>
                          </div>
                        </div>
                        <div class="product-content-list">
                          <div class="product-list-info">
                            <h4><a href="#"><%= product.title%></a></h4>
                            <span
                            class="text-decoration-line-through text-secondary"
                          >
                            ₹ <%= product.productPrice %>
                          </span>
                            <span>₹ <%= product.salePrice %></span>
                            <p>
                              <%= product.description%>
                            </p>
                          </div>
                          <div class="product-list-cart-wishlist">
                            <% if(!user) {%>
                            <div class="product-list-cart">
                              <a class="btn-hover list-btn-style" href="/login"
                                >add to cart</a
                              >
                            </div>
                              <% }else{ %>
                                <div class="product-list-cart">
                              <a class="btn-hover list-btn-style" onclick="addToCart('<%= product._id %>')"
                                >add to cart</a
                              >
                            </div>
                                <%}%>
                            <div class="product-list-wishlist">
                              <a class="btn-hover list-btn-wishlist" href="#">
                                <i class="pe-7s-like"></i>
                              </a>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                     <% }) %>
                   
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="pagination-style mt-30 text-center">
            <ul>
              <% if (currentPage> 1) { %>
              <li>
                <a href="?p=<%= parseInt(currentPage) - 1 %>"
                  ><i class="ti-angle-left"></i
                ></a>
              </li>
              <% } else { %>
              <li class="disabled">
                <span><i class="ti-angle-left"></i></span>
              </li>
              <% } %> <% for (let i=1; i <=totalPages; i++) { %>
              <li class="<%= i === currentPage ? 'active' : '' %>">
                <a href="?p=<%= i %>"> <%= i %> </a>
              </li>
              <% } %> <% if (currentPage < totalPages) { %>
              <li>
                <a href="?p=<%= parseInt(currentPage) + 1 %>">
                  <i class="ti-angle-right"></i
                ></a>
              </li>
              <% } else { %>
              <li class="disabled">
                <span><i class="ti-angle-right"></i></span>
              </li>
              <% } %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>

